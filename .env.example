# HepOps 运维自动化引擎配置
# 复制为 .env 并填入真实值

HEPOPS_DEBUG=true
HEPOPS_DATABASE_URL=sqlite+aiosqlite:///./hepops.db

# === 飞书 (Lark) ===
# 在飞书开放平台创建企业自建应用后获取
HEPOPS_LARK_APP_ID=cli_xxxx
HEPOPS_LARK_APP_SECRET=xxxx
HEPOPS_LARK_VERIFICATION_TOKEN=xxxx
HEPOPS_LARK_ENCRYPT_KEY=xxxx
# 飞书群机器人 webhook (用于发通知)
HEPOPS_LARK_WEBHOOK_NOTIFY=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
# 审批模板 code (在飞书管理后台创建审批模板后获取)
HEPOPS_LARK_APPROVAL_PIPELINE=approval_code_for_pipeline
HEPOPS_LARK_APPROVAL_RESOURCE=approval_code_for_resource
HEPOPS_LARK_APPROVAL_DOMAIN=approval_code_for_domain

# === 阿里云 ===
HEPOPS_ALI_ACCESS_KEY_ID=LTAI5xxxx
HEPOPS_ALI_ACCESS_KEY_SECRET=xxxx
HEPOPS_ALI_REGION_ID=cn-hangzhou
# 云效
HEPOPS_ALI_DEVOPS_ORG_ID=your_yunxiao_org_id
# ACR (容器镜像)
HEPOPS_ALI_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
HEPOPS_ALI_ACR_NAMESPACE=hep
# ACK
HEPOPS_ALI_ACK_CLUSTER_ID=your_ack_cluster_id
# DNS
HEPOPS_ALI_DOMAIN_NAME=hep.com.cn
# VPC (资源开通时需要)
HEPOPS_ALI_VPC_ID=vpc-xxxx
HEPOPS_ALI_VSWITCH_ID=vsw-xxxx
HEPOPS_ALI_SECURITY_GROUP_ID=sg-xxxx

# === 华为云 (GPU 等) ===
HEPOPS_HW_ACCESS_KEY=xxxx
HEPOPS_HW_SECRET_KEY=xxxx
HEPOPS_HW_REGION=cn-north-4
HEPOPS_HW_PROJECT_ID=xxxx

# === 腾讯云 (少量资源) ===
HEPOPS_TC_SECRET_ID=xxxx
HEPOPS_TC_SECRET_KEY=xxxx
HEPOPS_TC_REGION=ap-beijing
