# AgentOps — AI-native DevOps Platform
# Copy to .env and fill in real values

AGENTOPS_DEBUG=true
AGENTOPS_DATABASE_URL=sqlite+aiosqlite:///./agentops.db

# === 飞书 (Lark) ===
# 在飞书开放平台创建企业自建应用后获取
AGENTOPS_LARK_APP_ID=cli_xxxx
AGENTOPS_LARK_APP_SECRET=xxxx
AGENTOPS_LARK_VERIFICATION_TOKEN=xxxx
AGENTOPS_LARK_ENCRYPT_KEY=xxxx
# 飞书群机器人 webhook (用于发通知)
AGENTOPS_LARK_WEBHOOK_NOTIFY=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
# 审批模板 code (在飞书管理后台创建审批模板后获取)
AGENTOPS_LARK_APPROVAL_PIPELINE=approval_code_for_pipeline
AGENTOPS_LARK_APPROVAL_RESOURCE=approval_code_for_resource
AGENTOPS_LARK_APPROVAL_DOMAIN=approval_code_for_domain

# === 阿里云 ===
AGENTOPS_ALI_ACCESS_KEY_ID=LTAI5xxxx
AGENTOPS_ALI_ACCESS_KEY_SECRET=xxxx
AGENTOPS_ALI_REGION_ID=cn-hangzhou
# 云效
AGENTOPS_ALI_DEVOPS_ORG_ID=your_yunxiao_org_id
# ACR (容器镜像)
AGENTOPS_ALI_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
AGENTOPS_ALI_ACR_NAMESPACE=hep
# ACK
AGENTOPS_ALI_ACK_CLUSTER_ID=your_ack_cluster_id
# DNS
AGENTOPS_ALI_DOMAIN_NAME=hep.com.cn
# VPC (资源开通时需要)
AGENTOPS_ALI_VPC_ID=vpc-xxxx
AGENTOPS_ALI_VSWITCH_ID=vsw-xxxx
AGENTOPS_ALI_SECURITY_GROUP_ID=sg-xxxx

# === 华为云 (GPU 等) ===
AGENTOPS_HW_ACCESS_KEY=xxxx
AGENTOPS_HW_SECRET_KEY=xxxx
AGENTOPS_HW_REGION=cn-north-4
AGENTOPS_HW_PROJECT_ID=xxxx

# === 腾讯云 (少量资源) ===
AGENTOPS_TC_SECRET_ID=xxxx
AGENTOPS_TC_SECRET_KEY=xxxx
AGENTOPS_TC_REGION=ap-beijing

# === Default Images (optional overrides) ===
# AGENTOPS_ALI_ECS_IMAGE_ID=aliyun_3_x64_20G_alibase_20240819.vhd
# AGENTOPS_HW_ECS_IMAGE_ID=your_huawei_ubuntu_image_id
# AGENTOPS_HW_ECS_SUBNET_ID=your_huawei_subnet_id
# AGENTOPS_TC_CVM_IMAGE_ID=img-eb30mz89
